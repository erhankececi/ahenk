# =====================================================================
#  AHENK — Ortam değişkenleri (production contract)
#  Yerelde: .env.local. Canlıda: hosting (Vercel) Environment Variables.
#  Ayrıntı: ENVIRONMENT.md
# =====================================================================

# --- ZORUNLU: Supabase (Project Settings -> API) ---------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Sadece sunucu tarafı (admin işlemleri). ASLA NEXT_PUBLIC_ yapma, istemciye sızdırma!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- ZORUNLU: Uygulama adresi (OAuth callback + Stripe redirect) -----
# Canlıda gerçek alan adı: https://ahenk.app gibi.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- ÖDEME (web jeton satın alma — Stripe, OPSİYONEL) ----------------
# Boşsa: web'de jeton satın alma "ödeme yapılandırılmamış" (503) döner.
#   Demo (bedava jeton) YALNIZ production DIŞINDA çalışır → canlıda istismar yok.
# Doluysa: gerçek Stripe Checkout. Önce: npm i stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Production'da Stripe YOKKEN demoyu bilerek açmak istersen (önerilmez):
# ALLOW_DEMO_PURCHASE=true

# --- ABONELİK (mobil — RevenueCat, native build için) ----------------
REVENUECAT_WEBHOOK_AUTH=
NEXT_PUBLIC_RC_IOS_KEY=
NEXT_PUBLIC_RC_ANDROID_KEY=

# --- PUSH BİLDİRİM (web — VAPID, OPSİYONEL) --------------------------
# Boşsa: push sessizce kapalı (uygulama içi bildirimler yine çalışır).
# Anahtar üret:  npx web-push generate-vapid-keys   (ayrıca: npm i web-push)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:destek@ahenk.app

# --- SESLİ/GÖRÜNTÜLÜ ARAMA (TURN — production'da ŞART) ---------------
# Olmadan aynı ağ dışındaki aramalar bağlanamaz (yalnız STUN yetmez). Ayrıntı: CALLS.md
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USER=
NEXT_PUBLIC_TURN_CRED=

# =====================================================================
#  E-POSTA (kayıt doğrulama / şifre sıfırlama) UYGULAMADA değil,
#  Supabase Auth tarafında. SMTP buraya DEĞİL → Supabase Dashboard ->
#  Authentication -> SMTP Settings. Production için custom SMTP ZORUNLU
#  (önerilen: Resend) ve "mailer_autoconfirm" KAPATILMALI (canlıda e-posta
#  doğrulaması açık olmalı). Ayrıntı: ENVIRONMENT.md
# =====================================================================
