# =====================================================================
#  Ahenk Live — ortam değişkenleri
#  Yerelde: .env.local olarak kopyala. Canlıda: Vercel → Environment Variables.
# =====================================================================

# --- ZORUNLU: Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Opsiyonel: sadece sunucu tarafı (admin/servis işlemleri) ---
# ASLA NEXT_PUBLIC_ yapma, istemciye sızdırma.
SUPABASE_SERVICE_ROLE_KEY=

# --- Uygulama adresi (auth e-posta doğrulama / ödeme redirect) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- ÖDEME: iyzico (Türkiye) ---
# Boşsa: mock checkout akışı kullanılır (ödeme başlatma → callback → jeton yükleme simülasyonu).
# Doluysa: gerçek iyzico CheckoutForm entegrasyonu (lib/payments/iyzico.ts içinde tamamlanacak).
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
